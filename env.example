# ---- Database ----
# Local Postgres connection string. For cloud (Neon/Supabase/Railway), paste the
# pooled connection string they give you (usually needs ?sslmode=require).
DATABASE_URL=postgresql://sgjt:sgjt@localhost:5432/sgjt

# Set to "true" when your provider requires SSL (Neon, Supabase, Render, etc.)
PGSSL=false

# ---- Server ----
PORT=4000

# Comma-separated list of allowed origins for CORS.
# In dev the Vite proxy handles this; set your deployed frontend URL in prod.
CORS_ORIGIN=http://localhost:5173

# ---- Client (build-time) ----
# Where the frontend should send API requests. Leave blank to use the Vite
# dev proxy locally. In production set to your deployed API origin, e.g.
# https://sgjt-api.onrender.com
VITE_API_BASE=
